{
  // 编译 src/report/**(唯一含 .tsx 的运行时子树)为预编译 ESM,产物进 dist/report/**。
  // 详见 memory/report-build-rootdir-scope.md —— rootDir 必须是仓库的 "src"(不能收窄到
  // "src/report"),否则 src/report 对外的少量真实值依赖(shared/aggregate.ts、
  // shared/verdict.ts)会撞 TS6059(rootDir 之外的文件参与编译);outDir 相应设为
  // "dist"(不是 "dist/report"),这样 src/report/* 的产物仍落在 dist/report/*,只是
  // 附带在 dist/ 下多出几个极小的旁支目录(真正被运行时 import 的只有
  // dist/shared/aggregate.js 与 dist/shared/verdict.js;其余是类型层被动带入、编译后近乎
  // 空文件的旁支,不影响功能)。
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "declaration": true,
    "rootDir": "src",
    "outDir": "dist",
    // allowImportingTsExtensions(继承自基础 tsconfig,源码全按 NodeNext 约定写
    // `.ts`/`.tsx` 后缀)在真正产出 JS 时要求三选一:noEmit / emitDeclarationOnly /
    // rewriteRelativeImportExtensions。这里要真 JS 产物,选后者——相对导入里的
    // `.ts`/`.tsx` 后缀在产物里重写成 `.js`。
    "rewriteRelativeImportExtensions": true
  },
  "include": ["src/report"],
  // host.ts is the thin bridge show/view call INTO the compiled unit (architecture.md
  // "共享内核与两个宿主的代码边界"); it dynamically imports sibling dist/report/**
  // artifacts by relative path. It must stay raw source excluded from this build — compiling
  // it here would make it try to resolve its own dynamic dist/ imports against a dist/ that
  // doesn't exist yet on a fresh checkout (this build IS what produces dist/report/**).
  "exclude": ["src/report/**/*.test.ts", "src/report/**/*.test.tsx", "src/report/**/*.harness.ts", "src/report/runtime/host.ts"]
}
