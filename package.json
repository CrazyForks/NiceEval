    "@types/node": "^22.0.0",
    "@types/tar-stream": "^3.1.3",
    "@vitejs/plugin-react": "^6.0.3",
    "lucide-react": "^1.21.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "^5.6.0",
    "vite": "^8.1.0"
  }
