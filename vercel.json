{
  "buildCommand": "pnpm run site:build",
  "installCommand": "pnpm install",
  "rewrites": [
    {
      "source": "/docs",
      "destination": "https://fasteval.mintlify.site/docs"
    },
    {
      "source": "/docs/:match*",
      "destination": "https://fasteval.mintlify.site/docs/:match*"
    }
  ]
}
