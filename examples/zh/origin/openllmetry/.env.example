# 必填:OpenAI 兼容接口的 key。
OPENAI_API_KEY=sk-replace-me
# 可选:OpenAI 兼容网关
#OPENAI_BASE_URL=https://api.openai.com/v1
# 可选:默认 gpt-4o-mini
#AGENT_MODEL=gpt-4o-mini

# OpenLLMetry(@traceloop/node-server-sdk)导出 span 的标准 OTLP 端点。
# `docker compose up -d` 起本地 Jaeger 后指到这里;不设置就不导出(见 instrumentation.ts)。
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# 可选:server.ts 监听端口,默认 5488。
#PORT=5488
