# 被测应用怎么召模型:真的经 LangGraph 的 ReAct 循环召一个 OpenAI 兼容模型。
OPENAI_API_KEY=sk-replace-me
# 可选:OpenAI 兼容网关
#OPENAI_BASE_URL=https://api.openai.com/v1
# 可选:用的模型,默认 gpt-4o-mini。
#AGENT_MODEL=gpt-4o-mini

# 可选:server.ts 监听端口,默认 5388。
#PORT=5388

# --- LangSmith OTel-only 导出 ---
# 对应 docs-site/zh/guides/connect-otel.mdx "2. 应用侧" -> "LangGraph / LangChain"
# tab。三个 LANGSMITH_* 变量都要设;OTEL_EXPORTER_OTLP_ENDPOINT 用标准 OTel 变量名,
# 默认指向下面 docker-compose.yml 起的本地 Jaeger。这些变量只在进程启动时读一次
# (标准 OTel SDK 限制),改了要重启进程才生效。
#LANGSMITH_TRACING=true
#LANGSMITH_OTEL_ENABLED=true
#LANGSMITH_OTEL_ONLY=true
#OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces
