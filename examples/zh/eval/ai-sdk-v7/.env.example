# OpenAI 兼容 provider 的鉴权(src/models.ts 里读)。
OPENAI_API_KEY=sk-replace-me
# 可选:OpenAI-compatible 网关
#OPENAI_BASE_URL=https://api.openai.com/v1

DEEPSEEK_API_KEY=sk-replace-me
#DEEPSEEK_BASE_URL=https://api.deepseek.com

# 可选:没传参数时用的默认模型。
#AGENT_MODEL=deepseek-v4-flash

# 可选:server.ts 监听端口,默认 5188。
#PORT=5188

# 可选:experiments/assistant.ts 声明了 capabilities.tracing 后,同一批 span 双发到你自己的
# OTLP 观测后端(Langfuse / SigNoz / 生产 collector)。不设就只发给 niceeval 自己的接收器。
#OTLP_BACKEND_URL=
