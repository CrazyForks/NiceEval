# 真的过一遍 LangChain 的 create_agent，需要一个 OpenAI 兼容的模型访问凭证。
OPENAI_API_KEY=

# 用 OpenAI 兼容网关（DeepSeek / 自建代理等）时改这个，留空则用 SDK 默认的 OpenAI 官方地址。
OPENAI_BASE_URL=
AGENT_MODEL=gpt-4o-mini

# FastAPI 监听端口。
PORT=8787

# phoenix.otel.register() 读它决定 span 发去哪；不设的话依次退回
# OTEL_EXPORTER_OTLP_ENDPOINT、再没有就默认 localhost。不管这里写的端口是几，
# 没显式指定 protocol="http/protobuf" 时 phoenix.otel 都会把端口强制换成
# gRPC 端口（默认 4317）——docker-compose.yml 起的本地 Phoenix 两个端口都开着
# （6006 给 UI/HTTP，4317 给 gRPC），留空或按下面这样写都能直接连上。
PHOENIX_COLLECTOR_ENDPOINT=http://localhost:6006
# Phoenix UI 里给这批 trace 分组用的项目名。
PHOENIX_PROJECT_NAME=niceeval-openinference-example

# --- niceeval 侧,不是 app 的一部分 ---
# judge(t.judge.autoevals.*)走单独的网关/key,不复用上面那对 OPENAI_*。原因:autoevals 的
# closedQA/factuality/summarizes 都强制 tool_choice 指定函数,而 api.deepseek.com 直连
# 对 deepseek-v4-flash / deepseek-v4-pro 两个模型都报「Thinking mode does not support
# this tool_choice」。不设就退回 OPENAI_BASE_URL/OPENAI_API_KEY(见 src/scoring/judge.ts)。
#NICEEVAL_JUDGE_BASE=https://api.openai.com/v1
#NICEEVAL_JUDGE_KEY=sk-replace-me
